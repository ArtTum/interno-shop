{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "aws/aws-sdk-php": "^3.337",
        "guzzlehttp/guzzle": "^7.9",
        "intervention/image": "^2.7",
        "laravel/framework": "^11.9",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "league/flysystem-ftp": "3.0",
        "league/flysystem-sftp-v3": "3.0",
        "league/iso3166": "^4.3",
        "league/oauth2-client": "*",
        "league/openapi-psr7-validator": "^0.21.0",
        "microsoft/microsoft-graph": "^1.0",
        "milon/barcode": "^12.0",
        "mpdf/mpdf": "^8.2",
        "netresearch/jsonmapper": "^4.0.0",
        "php-http/discovery": "^1.10.0",
        "php-http/guzzle7-adapter": "^1.0",
        "php-http/httplug": "^2.2.0",
        "php-http/logger-plugin": "^1.2.1",
        "picqer/php-barcode-generator": "^3.2",
        "predis/predis": "^2.2",
        "sentry/sentry-laravel": "^4.13",
        "spatie/array-to-xml": "^3.3",
        "srmklive/paypal": "*",
        "stichoza/google-translate-php": "^5.2",
        "stripe/stripe-php": "^16.1",
        "symfony/console": "^7.1 <7.4",
        "tightenco/ziggy": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.1",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/CommonHelper.php",
            "app/Helpers/DBHelper.php",
            "app/Helpers/APlusContentHelper.php",
            "app/Helpers/ZIPRulesHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
